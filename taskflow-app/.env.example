# Variables d'environnement pour l'application Taskflow
# Copiez ce fichier en .env et ajustez les valeurs selon vos besoins

# Configuration de la base de données PostgreSQL
# Le nom d'hôte 'postgres' correspond au nom du service dans docker-compose.yml
DB_HOST=postgres

# Port interne de la base de données PostgreSQL dans le conteneur
DB_PORT=5432

# Nom de la base de données à créer
DB_NAME=taskflow

# Nom d'utilisateur pour la base de données
DB_USER=taskflow

# Mot de passe pour l'utilisateur de la base de données
# IMPORTANT: Utilisez un mot de passe fort en production
DB_PASSWORD=replace_with_a_strong_password

# Configuration Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Configuration JWT
JWT_SECRET=replace_with_a_strong_jwt_secret

# Port de l'API Gateway
API_GATEWAY_PORT=3000

# Port du User Service
USER_SERVICE_PORT=3001

# Port du Task Service
TASK_SERVICE_PORT=3002

# Port du Notification Service
NOTIFICATION_SERVICE_PORT=3003

# Configuration OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=taskflow-app
OTEL_RESOURCE_ATTRIBUTES=service.name=taskflow-app,service.version=1.0.0

# Niveau de log
LOG_LEVEL=info
